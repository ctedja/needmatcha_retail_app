# Recommended: Supabase pooler URL (IPv4 friendly).
# Example:
# postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
SUPABASE_DB_POOLER_URL=

# Optional fallback: direct DB URL (often IPv6-only).
# Example:
# postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
SUPABASE_DB_URL=

# Optional local override:
PORT=5000

# Optional local SSL override (use only for local debugging on restrictive networks):
# DB_SSLMODE=disable

# Optional reliability tuning (safe defaults are used if omitted):
# DB_CONNECT_TIMEOUT_SECONDS=10
# DB_STATEMENT_TIMEOUT_MS=12000
# DB_IDLE_IN_TX_TIMEOUT_MS=15000
# DB_POOL_MIN_SIZE=1
# DB_POOL_MAX_SIZE=10
# DB_POOL_ACQUIRE_TIMEOUT_SECONDS=5
# DB_WRITE_RETRIES=2
# DB_WRITE_RETRY_DELAY_MS=250

# Simple database admin gate (for /orders and order management APIs)
DB_ADMIN_PASSWORD=change-this-password
FLASK_SECRET_KEY=change-this-secret-key
